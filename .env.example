# Directory containing PDF documents
# Should have an 'unprocessed' subdirectory for incoming files
SCAN_DIR=/path/to/your/pdfs

# Config directory containing:
#   - rclone.conf (cloud storage authentication)
#   - post-scan-commands/ (optional directory with executable scripts)
CONFIG_DIR=/path/to/your/config

# Timezone for container and timestamps
# Sets the TZ environment variable inside the container
# Affects log timestamps, file naming timestamps, and post-scan hook variables
# Format: Area/Location (see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
# Examples: America/Chicago, America/New_York, Europe/London, Asia/Tokyo
TIMEZONE=America/Chicago

# Rclone remote and destination path
# Format: RemoteName:path/to/destination
# The RemoteName must match a remote configured in rclone.conf
# Examples:
#   Dropbox:Cabinet/Documents
#   GoogleDrive:Documents/PDFs
#   S3:my-bucket/documents
#   OneDrive:Documents
RCLONE_REMOTE=Dropbox:Cabinet/Documents

# User and Group ID for file ownership
# Set these to match the owner of your scan directory
# Use 'id username' to find UID/GID, or 'ls -n /path/to/scan/dir' to see numeric IDs
# Default: 1000:1000 (typical first user on Linux)
# Example for SMB/CIFS shares: Use the UID:GID of the user that owns the share
PUID=1000
PGID=1000

# Check interval in minutes - how often to scan for new PDFs
# Script has built-in locking to prevent concurrent runs
INTERVAL_MINUTES=1

# Maximum number of PDFs to process in parallel
# Higher values = faster processing but more CPU/memory usage
# Default is 1 (sequential). Increase for faster processing on powerful systems.
# Recommended: 3-4 for desktop/server, 5-8 for powerful servers
MAX_PARALLEL_JOBS=1

# File age threshold in minutes - only process files older than this
# Prevents processing files that are still being written
MINUTES_OLD=1

# =============================================================================
# AI-POWERED DOCUMENT DETECTION (enabled by default in docker-compose.yml)
# =============================================================================
# The full image (:latest) includes AI detection enabled by default.
# Use :lite image or set ENABLE_DETECTION=false to disable.
#
# The vision AI model is baked into the image - no additional setup required.
# Image size: ~7GB (full) or ~800MB (lite)

# Enable intelligent document detection for multi-document scans
# When enabled, scans containing multiple documents (e.g., a stack of mail)
# will be automatically detected and split into separate PDFs
# Works best with GPU (NVIDIA/AMD); falls back to CPU with warning if no GPU
ENABLE_DETECTION=true

# Enable document classification for smart file naming
# When enabled, detected documents are named based on content:
#   e.g., "2025-01-15_Comcast_Bill_acct1234.pdf" instead of "doc001.pdf"
# Only works when ENABLE_DETECTION=true
# Default is true (matches docker-compose.yml and the image default).
ENABLE_CLASSIFICATION=true

# Note: If no GPU is detected, AI detection automatically falls back to CPU
# with a warning. CPU is ~10x slower. To avoid slow processing without a GPU,
# either use the lite image or set ENABLE_DETECTION=false.

# --- Detection reliability (auto-disable + backoff) --------------------------
# If AI detection fails on this many consecutive runs, it is automatically
# disabled and processing falls back to plain OCR. Detection auto-recovers as
# soon as a GPU re-check passes. Set to 0 to disable this safety net.
DETECTION_FAILURE_THRESHOLD=3

# Once auto-disabled, minimum minutes between re-logging the warning, so a
# frequent scan loop doesn't spam logs/notifications while the GPU is down.
DETECTION_BACKOFF_MINUTES=15

# Post-scan hooks (/config/post-scan-commands) receive these extra variables so
# they can notify on success vs. failure:
#   SCAN_STATUS                    success | partial | failure
#   DETECTION_FAILURES             detection failures in this run
#   DETECTION_CONSECUTIVE_FAILURES running consecutive-failure count
#   DETECTION_AUTO_DISABLED        true when detection is currently auto-disabled
